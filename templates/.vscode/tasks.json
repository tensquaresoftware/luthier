{{
    "version": "2.0.0",
    "tasks": [
        {{
            "label": "Build: Standalone",
            "type": "cmake",
            "command": "build",
            "preset": "${{command:cmake.activeBuildPresetName}}",
            "targets": ["{projectName}_Standalone"],
            "group": "build",
            "problemMatcher": []
        }},
        {{
            "label": "Build: AU",
            "type": "cmake",
            "command": "build",
            "preset": "${{command:cmake.activeBuildPresetName}}",
            "targets": ["{projectName}_AU"],
            "group": "build",
            "problemMatcher": []
        }},
        {{
            "label": "Build: VST3",
            "type": "cmake",
            "command": "build",
            "preset": "${{command:cmake.activeBuildPresetName}}",
            "targets": ["{projectName}_VST3"],
            "group": "build",
            "problemMatcher": []
        }},
        {{
            "label": "Build: All",
            "type": "cmake",
            "command": "build",
            "preset": "${{command:cmake.activeBuildPresetName}}",
            "group": {{
                "kind": "build",
                "isDefault": true
            }},
            "problemMatcher": []
        }},
        {{
            "label": "Clean",
            "type": "cmake",
            "command": "clean",
            "preset": "${{command:cmake.activeBuildPresetName}}",
            "group": "build",
            "problemMatcher": []
        }},
        {{
            "label": "CMake: Configure",
            "type": "cmake",
            "command": "configure",
            "preset": "${{command:cmake.activeConfigurePresetName}}",
            "problemMatcher": []
        }},
        {{
            "label": "Purge Builds",
            "type": "shell",
            "command": "rm",
            "args": ["-rf", "Builds"],
            "options": {{
                "cwd": "${{workspaceFolder}}"
            }},
            "windows": {{
                "command": "powershell",
                "args": [
                    "-Command",
                    "Remove-Item -Recurse -Force Builds -ErrorAction SilentlyContinue"
                ]
            }},
            "problemMatcher": []
        }},
        {{
            "label": "Purge Builds and Configure",
            "dependsOn": ["Purge Builds", "CMake: Configure"],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }}
    ]
}}
